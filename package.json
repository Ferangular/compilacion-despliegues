{
  "name": "compilacion-despliegues",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "fpatino": "ng serve --host 0.0.0.0 --port 4500 --open --configuration fpatino",
    "dev": "ng serve --open",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:debug-prod": "ng build --configuration debug-production",
    "build:optimized": "node scripts/build-optimized.js",
    "build:netlify": "ng build --configuration production --output-path dist/compilacion-despliegues/browser",
    "analyze": "ng build --configuration production --stats-json && npx esbuild-visualizer --metadata dist/compilacion-despliegues/stats.json --open",
    "analyze:bundles": "ng build --configuration production --stats-json && npx webpack-bundle-analyzer dist/compilacion-despliegues/browser/stats.json --mode static --report bundle-report.html",
    "analyze:maps": "ng build --configuration debug-production",
    "analyze:sme": "npm run analyze:maps && npx source-map-explorer 'dist/compilacion-despliegues/browser/*.js' --html bundle-analysis.html --gzip --exclude-source-map",
    "analyze:simple": "npm run analyze:maps && npx source-map-explorer 'dist/compilacion-despliegues/browser/main*.js' --html main-bundle.html --gzip --exclude-source-map",
    "watch": "ng build --watch --configuration development",
    "preview": "serve dist/compilacion-despliegues/browser",
    "test": "ng test",
    "test:ci": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint && npm run build:prod",
    "prepare": "husky",
    "commit": "git-cz"
  },
  "private": true,
  "packageManager": "npm@11.4.0",
  "dependencies": {
    "@angular/common": "21.2.5",
    "@angular/compiler": "21.2.5",
    "@angular/core": "21.2.5",
    "@angular/forms": "21.2.5",
    "@angular/platform-browser": "21.2.5",
    "@angular/router": "21.2.5",
    "@angular/service-worker": "21.2.5",
    "@jsverse/transloco": "^8.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.5",
    "@angular/cli": "21.2.5",
    "@angular/compiler-cli": "21.2.5",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "angular-eslint": "21.3.0",
    "esbuild-visualizer": "^0.7.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "sass": "^1.98.0",
    "serve": "^14.2.6",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "*.{ts,html,css,scss,js,json,md}": [
      "prettier --write"
    ],
    "*.ts": [
      "eslint --fix"
    ]
  }
}
